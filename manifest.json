{
  "manifest_version": 3,
  "name": "PixPluck - Pexels Media Grabber",
  "short_name": "PixPluck",
  "version": "1.0.0",
  "description": "Pluck every video and image out of any Pexels page, preview them, and download one, some, or all in a click.",
  "author": "Muhammad Abdullah Awais",
  "homepage_url": "https://www.abdullahawais.com",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PixPluck",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["scripting", "downloads", "storage"],
  "host_permissions": ["*://*.pexels.com/*"]
}
